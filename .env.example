# Rate Limiter Service (.env.example)
NODE_ENV=development
PORT=3002

# Redis (shared across instances for distributed correctness)
REDIS_URI=redis://localhost:6379
REDIS_PREFIX=app_
REDIS_TIMEOUT_MS=5000
REDIS_MAX_RETRIES=10

# Rate limiter defaults (optional)
RATE_LIMIT_DEFAULT_LIMIT=100
RATE_LIMIT_DEFAULT_WINDOW_MS=60000
# 1 = fail open (allow) if Redis errors, 0 = fail closed (deny)
RATE_LIMIT_FAIL_OPEN=1

